{
  "manifest_version": 3,
  "name": "LUMA 2.0 - W Command Center",
  "author": "Drecko.Vibe",
  "version": "2.0.0",
  "description": "Monitoramento Avançado e UI W",
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["*://*.clinicorp.tech/*", "*://clinicorp.com/*"], 
      "css": [
        "css/fab.css",
        "css/panel.css" 
      ],
      "js": [
        "js/exceljs.min.js",
        "js/inject.js",
        "js/fab_logic.js",
        "js/panel.js"
      ]
    }
  ],
  "permissions": ["storage"],
  "host_permissions": ["*://*.clinicorp.tech/*", "*://clinicorp.com/*"]
}